# BetsAPI
BETSAPI_TOKEN=your_betsapi_token_here
BETSAPI_BASE_URL=https://api.b365api.com/v3

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Database
DATABASE_URL=sqlite+aiosqlite:///data/fifa_bet.db

# Logging
LOG_LEVEL=INFO

# Liga
DEFAULT_LEAGUE_NAME=Esoccer Battle - 8 mins play
DEFAULT_LEAGUE_ID=

# Polling
POLL_INTERVAL_SECONDS=30
ODDS_POLL_INTERVAL_SECONDS=15

# Stats Engine Thresholds
MIN_EDGE=0.05
MIN_EV=0.03
MIN_TRUE_PROB=0.55
MIN_GLOBAL_SAMPLE=500
MIN_PLAYER_SAMPLE=5
MIN_TEAM_SAMPLE=10
MIN_ODDS=1.40
MAX_ODDS=4.00
KELLY_FRACTION=0.25
COLD_START_DAYS=90
REGIME_WINDOW=50

# Timezone
TIMEZONE=America/Sao_Paulo
